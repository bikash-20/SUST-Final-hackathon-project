# Render: set this to the managed Postgres direct internal connection string.
# The application uses only its host/port/database and authenticates with the
# scoped roles below. Local development may omit it and use DB_HOST/PORT/NAME.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codex_demo
DB_APP_USER=app_shared
DB_APP_PASSWORD=change_me_shared
DB_BKASH_USER=app_bkash
DB_BKASH_PASSWORD=change_me_bkash
DB_NAGAD_USER=app_nagad
DB_NAGAD_PASSWORD=change_me_nagad
DB_ROCKET_USER=app_rocket
DB_ROCKET_PASSWORD=change_me_rocket
DEMO_AGENT_ID=00000000-0000-0000-0000-000000000001
ANOMALY_ALLOWLISTED_PROVIDERS=
HISTORICAL_WINDOW_DAYS=30
# Comma-separated exact browser origins, with no path or trailing slash.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Render migration only: direct owner URL, never a PgBouncer/pool URL.
MIGRATION_DATABASE_URL=
